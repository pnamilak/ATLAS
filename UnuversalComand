  --volname "ATLAS" \
  --window-pos 200 120 \
  --window-size 800 420 \
  --icon-size 120 \
  --icon "ATLAS.app" 200 190 \
  --hide-extension "ATLAS.app" \
  --app-drop-link 600 185 \
  "ATLAS-universal-mac.dmg" \
  "ATLAS.app"
